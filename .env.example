# Coralogix send-your-data API key (private, do not commit)
# Consumed by the otel-collector container — not by the Node app directly.
CX_PRIVATE_KEY=

# Coralogix region (eu1, eu2, us1, us2, ap1, ap2, ap3, etc.)
CX_DOMAIN=eu1.coralogix.com

# Service / application labels — applied by the collector's coralogix exporter.
CX_APPLICATION_NAME=code-agents-observability
CX_SUBSYSTEM_NAME=sessions-api

# OpenTelemetry resource attribute (also used as the SDK's service.name)
OTEL_SERVICE_NAME=sessions-api

# Where the Node SDK ships OTLP. Points at the local otel-collector
# (docker-compose service: otel-collector). The collector then forwards to
# Coralogix and runs the spanmetrics connector that powers APM.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Postgres connection. Leave unset to run against the in-memory adapter
# (state is lost on restart). Match the credentials in docker-compose.yml.
# In EKS this points at the RDS endpoint with sslmode=require.
DATABASE_URL=postgres://app:app@localhost:5432/code_agents
